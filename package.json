{
  "name": "multilanguage-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"{src,test}/**/*.{js,ts,json,tsx,jsx}\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.{js,ts,json,tsx,jsx}\" ",
    "format": "prettier --write \"(src|test)/**/*.(js|ts|json|tsx|jsx)\"",
    "format:check": "prettier --check \"(src|test)/**/*.(js|ts|json|tsx|jsx)\"",
    "type:check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.476.0",
    "next": "15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.85.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "prettier": "^3.5.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
